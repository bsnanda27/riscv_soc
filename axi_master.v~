// =============================================================================
//  axi_master.v  —  AXI4-Lite Master for RV32I Core Data Bus
//
//  Interfaces the processor MW-stage data bus to an AXI4-Lite fabric.
//  - Single outstanding transaction (no pipelining)
//  - Supports byte / halfword / word accesses via mem_acc_mode
//  - Generates WSTRB from address[1:0] + mem_acc_mode
//  - Drives core_stall to freeze the pipeline while AXI is busy
//  - Active-low async reset (aresetn) matched to AXI convention
//
//  Port map matches processor.v MW-stage signals:
//    core_mem_we      ← wr_en_MW
//    core_mem_re      ← rd_en_MW
//    core_mem_addr    ← opr_res_MW
//    core_mem_wdata   ← rdata2_MW
//    core_mem_rdata   → (feeds back into pipeline / wbmux)
//    core_mem_acc     ← mem_acc_mode_MW  (2:0)
//    core_stall       → stallIF / flushDE
// =============================================================================

`timescale 1ns/1ps

module axi_master #(
    parameter ADDR_WIDTH = 32,
    parameter DATA_WIDTH = 32
)(
    // -------------------------------------------------------------------------
    //  Global
    // -------------------------------------------------------------------------
    input  wire                    aclk,
    input  wire                    aresetn,        // active-low synchronous reset

    // -------------------------------------------------------------------------
    //  Processor MW-stage data bus
    // -------------------------------------------------------------------------
    input  wire                    core_mem_we,    // data-memory write enable (MW stage)
    input  wire                    core_mem_re,    // data-memory read  enable (MW stage)
    input  wire [ADDR_WIDTH-1:0]   core_mem_addr,  // byte address from ALU result
    input  wire [DATA_WIDTH-1:0]   core_mem_wdata, // write data (rs2 value)
    input  wire [2:0]              core_mem_acc,   // access mode: {sign,size[1:0]}
                                                   //   size: 00=byte 01=half 10=word
    output reg  [DATA_WIDTH-1:0]   core_mem_rdata, // read data back to WB mux
    output wire                    core_stall,     // hold pipeline while AXI busy

    // -------------------------------------------------------------------------
    //  AXI4-Lite Master — Write Address channel
    // -------------------------------------------------------------------------
    output reg  [ADDR_WIDTH-1:0]   M_AXI_AWADDR,
    output reg  [2:0]              M_AXI_AWPROT,  // 3'b000 (unprivileged, non-secure, data)
    output reg                     M_AXI_AWVALID,
    input  wire                    M_AXI_AWREADY,

    // -------------------------------------------------------------------------
    //  AXI4-Lite Master — Write Data channel
    // -------------------------------------------------------------------------
    output reg  [DATA_WIDTH-1:0]   M_AXI_WDATA,
    output reg  [DATA_WIDTH/8-1:0] M_AXI_WSTRB,
    output reg                     M_AXI_WVALID,
    input  wire                    M_AXI_WREADY,

    // -------------------------------------------------------------------------
    //  AXI4-Lite Master — Write Response channel
    // -------------------------------------------------------------------------
    input  wire [1:0]              M_AXI_BRESP,
    input  wire                    M_AXI_BVALID,
    output reg                     M_AXI_BREADY,

    // -------------------------------------------------------------------------
    //  AXI4-Lite Master — Read Address channel
    // -------------------------------------------------------------------------
    output reg  [ADDR_WIDTH-1:0]   M_AXI_ARADDR,
    output reg  [2:0]              M_AXI_ARPROT,  // 3'b000
    output reg                     M_AXI_ARVALID,
    input  wire                    M_AXI_ARREADY,

    // -------------------------------------------------------------------------
    //  AXI4-Lite Master — Read Data channel
    // -------------------------------------------------------------------------
    input  wire [DATA_WIDTH-1:0]   M_AXI_RDATA,
    input  wire [1:0]              M_AXI_RRESP,
    input  wire                    M_AXI_RVALID,
    output reg                     M_AXI_RREADY
);

    // =========================================================================
    //  FSM encoding
    // =========================================================================
    localparam [2:0]
        ST_IDLE   = 3'd0,
        ST_WADDR  = 3'd1,   // present AWADDR
        ST_WDATA  = 3'd2,   // present WDATA
        ST_WRESP  = 3'd3,   // wait for BRESP
        ST_RADDR  = 3'd4,   // present ARADDR
        ST_RDATA  = 3'd5;   // wait for RDATA

    reg [2:0] state, next_state;

    // =========================================================================
    //  Request latch — capture MW-stage values the moment a request appears
    //  so the pipeline can stall without losing data.
    // =========================================================================
    reg                    req_we;
    reg [ADDR_WIDTH-1:0]   req_addr;
    reg [DATA_WIDTH-1:0]   req_wdata;
    reg [2:0]              req_acc;

    wire core_req = core_mem_we | core_mem_re;

    always @(posedge aclk) begin
        if (!aresetn) begin
            req_we    <= 1'b0;
            req_addr  <= {ADDR_WIDTH{1'b0}};
            req_wdata <= {DATA_WIDTH{1'b0}};
            req_acc   <= 3'b010;            // default: word
        end else if (state == ST_IDLE && core_req) begin
            req_we    <= core_mem_we;
            req_addr  <= core_mem_addr;
            req_wdata <= core_mem_wdata;
            req_acc   <= core_mem_acc;
        end
    end

    // =========================================================================
    //  WSTRB generation
    //  mem_acc_mode[1:0]:  00=byte  01=halfword  10/11=word
    //  Byte offset from addr[1:0]
    // =========================================================================
    reg [DATA_WIDTH/8-1:0] wstrb_comb;

    always @* begin
        case (req_acc[1:0])
            2'b00: begin   // byte
                case (req_addr[1:0])
                    2'b00: wstrb_comb = 4'b0001;
                    2'b01: wstrb_comb = 4'b0010;
                    2'b10: wstrb_comb = 4'b0100;
                    2'b11: wstrb_comb = 4'b1000;
                endcase
            end
            2'b01: begin   // halfword
                case (req_addr[1])
                    1'b0: wstrb_comb = 4'b0011;
                    1'b1: wstrb_comb = 4'b1100;
                endcase
            end
            default: wstrb_comb = 4'b1111;  // word
        endcase
    end

    // =========================================================================
    //  Read-data sign/zero extension
    //  mem_acc_mode[2]: 1=signed  0=unsigned
    //  mem_acc_mode[1:0]: size
    // =========================================================================
    reg [DATA_WIDTH-1:0] rdata_extended;
    reg [7:0]  byte_sel;
    reg [15:0] half_sel;

    always @* begin
        // Pick the correct byte/half from the 32-bit RDATA using address offset
        case (M_AXI_RDATA[1:0])   // use live addr bits from req_addr
            2'b00: byte_sel = M_AXI_RDATA[7:0];
            2'b01: byte_sel = M_AXI_RDATA[15:8];
            2'b10: byte_sel = M_AXI_RDATA[23:16];
            2'b11: byte_sel = M_AXI_RDATA[31:24];
        endcase
        half_sel = req_addr[1] ? M_AXI_RDATA[31:16] : M_AXI_RDATA[15:0];

        case (req_acc[1:0])
            2'b00: begin   // byte
                if (req_acc[2])  // signed
                    rdata_extended = {{24{byte_sel[7]}}, byte_sel};
                else
                    rdata_extended = {24'b0, byte_sel};
            end
            2'b01: begin   // halfword
                if (req_acc[2])  // signed
                    rdata_extended = {{16{half_sel[15]}}, half_sel};
                else
                    rdata_extended = {16'b0, half_sel};
            end
            default: rdata_extended = M_AXI_RDATA;  // word — pass through
        endcase
    end

    // =========================================================================
    //  FSM — state register
    // =========================================================================
    always @(posedge aclk) begin
        if (!aresetn)
            state <= ST_IDLE;
        else
            state <= next_state;
    end

    // =========================================================================
    //  FSM — next-state + output logic (Mealy / registered outputs)
    // =========================================================================
    always @* begin
        // ---------- safe defaults ----------
        next_state     = state;
        M_AXI_AWADDR   = req_addr;
        M_AXI_AWPROT   = 3'b000;
        M_AXI_AWVALID  = 1'b0;
        M_AXI_WDATA    = req_wdata;
        M_AXI_WSTRB    = wstrb_comb;
        M_AXI_WVALID   = 1'b0;
        M_AXI_BREADY   = 1'b0;
        M_AXI_ARADDR   = req_addr;
        M_AXI_ARPROT   = 3'b000;
        M_AXI_ARVALID  = 1'b0;
        M_AXI_RREADY   = 1'b0;

        case (state)
            // ------------------------------------------------------------------
            ST_IDLE: begin
                if (core_req) begin
                    if (core_mem_we)
                        next_state = ST_WADDR;
                    else
                        next_state = ST_RADDR;
                end
            end

            // ------------------------------------------------------------------
            // Write path: address and data channels can be accepted in any order
            // by the slave (AXI4-Lite spec §A3.3), so we issue both simultaneously.
            // ------------------------------------------------------------------
            ST_WADDR: begin
                M_AXI_AWADDR  = req_addr;
                M_AXI_AWVALID = 1'b1;
                M_AXI_WDATA   = req_wdata;
                M_AXI_WSTRB   = wstrb_comb;
                M_AXI_WVALID  = 1'b1;

                // Both channels accepted?
                if (M_AXI_AWREADY && M_AXI_WREADY)
                    next_state = ST_WRESP;
                // Only address accepted
                else if (M_AXI_AWREADY && !M_AXI_WREADY)
                    next_state = ST_WDATA;
                // Only data accepted — stay and keep AWVALID high
                // (slave must accept AWADDR; stay in ST_WADDR)
            end

            // ------------------------------------------------------------------
            ST_WDATA: begin
                // AWADDR already accepted; just need WREADY
                M_AXI_WDATA  = req_wdata;
                M_AXI_WSTRB  = wstrb_comb;
                M_AXI_WVALID = 1'b1;
                if (M_AXI_WREADY)
                    next_state = ST_WRESP;
            end

            // ------------------------------------------------------------------
            ST_WRESP: begin
                M_AXI_BREADY = 1'b1;
                if (M_AXI_BVALID)
                    next_state = ST_IDLE;
            end

            // ------------------------------------------------------------------
            ST_RADDR: begin
                M_AXI_ARADDR  = req_addr;
                M_AXI_ARVALID = 1'b1;
                if (M_AXI_ARREADY)
                    next_state = ST_RDATA;
            end

            // ------------------------------------------------------------------
            ST_RDATA: begin
                M_AXI_RREADY = 1'b1;
                if (M_AXI_RVALID)
                    next_state = ST_IDLE;
            end

            default: next_state = ST_IDLE;
        endcase
    end

    // =========================================================================
    //  Capture read data on the handshake beat
    // =========================================================================
    always @(posedge aclk) begin
        if (!aresetn)
            core_mem_rdata <= {DATA_WIDTH{1'b0}};
        else if (state == ST_RDATA && M_AXI_RVALID && M_AXI_RREADY)
            core_mem_rdata <= rdata_extended;
    end

    // =========================================================================
    //  Pipeline stall: assert whenever the FSM is not idle
    //  The processor hazard unit already has stallIF / flushDE gating;
    //  tie core_stall directly to stallIF or a new "dmem_busy" input.
    // =========================================================================
    assign core_stall = (state != ST_IDLE) || (core_req && (state == ST_IDLE));
    // Goes high on the same cycle the request is seen, falls the cycle after
    //   ST_WRESP/ST_RDATA accepts its final handshake.

endmodule
