// Forwarding (MW->DE) + load-use stall + branch flush.
// 'else' branches added on forward_a/forward_b to remove the original latch.
`timescale 1ns/1ps
module hazard_unit (
    // Forwarding
    input      [ 4:0] rs1_DE,
    input      [ 4:0] rs2_DE,
    input      [ 4:0] rd_MW,
    input             rf_en_MW,
    output reg        forward_a,
    output reg        forward_b,
    // Stalling / flushing
    input      [31:0] inst_IF,
    input      [ 4:0] rd_DE,
    input      [ 1:0] wb_sel_DE,
    input             br_taken,
    output reg        stall_IF,
    output reg        flush_DE,
    
    input wire dmem_stall,

);
    reg stall_lw;

    // operand A forward
    always @(*) begin
        if (rf_en_MW && (rs1_DE == rd_MW) && (rs1_DE != 5'b00000))
            forward_a = 1'b1;
        else
            forward_a = 1'b0;
    end

    // operand B forward
    always @(*) begin
        if (rf_en_MW && (rs2_DE == rd_MW) && (rs2_DE != 5'b00000))
            forward_b = 1'b1;
        else
            forward_b = 1'b0;
    end

    // load-use stall + flush
    always @(*) begin
        if (wb_sel_DE == 2'b10) begin // load in DE
            if ((inst_IF[19:15] == rd_DE) || (inst_IF[24:20] == rd_DE))
                stall_lw = 1'b1;
            else
                stall_lw = 1'b0;
        end
        else
            stall_lw = 1'b0;

        stall_IF = stall_lw | dem_stall;
        flush_DE = stall_lw | dem_stall | br_taken;
    end
endmodule

