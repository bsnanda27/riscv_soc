`timescale 1ns/1ps
`default_nettype none

// =============================================================================
// Testbench: tb_axi_wrapper
//
// Purpose:
// - Smoke-test axi_wrapper integration
// - Verify AXI-Lite path from core-side requests into:
//     S0: axi_dmem
//     S1: axi_gpio
//     S2: axi_spi
// - Does NOT require the user's full processor RTL to run
//   because this TB provides a behavioral stub for 'processor'.
//
// Expected sequence from stub processor:
//   1) Write 0xA5A5000F to GPIO @ 0x4000_0000
//   2) Read  GPIO_IN     from 0x4000_0004
//   3) Write 0x0000003C to DMEM @ 0x0000_0010
//   4) Read  DMEM        from 0x0000_0010
//   5) Write SPI_TX      @ 0x4000_1004 = 0x5A
//   6) Write SPI_CTRL    @ 0x4000_1000 = start/en
//   7) Read  SPI_STATUS  @ 0x4000_100C
//   8) Read  SPI_RX      @ 0x4000_1008
//
// Notes:
// - This TB is intended for bring-up of axi_wrapper / axi_master / interconnect.
// - Replace the stub 'processor' with your real processor later.
// =============================================================================

module tb_axi_wrapper;

    reg         clk;
    reg         rst;
    reg  [31:0] gpio_in;
    wire [31:0] gpio_out;
    wire [31:0] gpio_dir;
    wire        spi_sck;
    wire        spi_mosi;
    reg         spi_miso;
    wire        spi_cs_n;

    wire [31:0] pc_debug;
    wire [31:0] inst_debug;
    wire        rf_we;
    wire [4:0]  rf_waddr;
    wire [31:0] rf_wdata;
    wire        br_taken_dbg;
    wire        trap_taken;
    wire [31:0] epc_debug;
    wire        timer_irq_dbg;

    // DUT ---------------------------------------------------------------------
    axi_wrapper dut (
        .clk           (clk),
        .rst           (rst),
        .gpio_in       (gpio_in),
        .gpio_out      (gpio_out),
        .gpio_dir      (gpio_dir),
        .spi_sck       (spi_sck),
        .spi_mosi      (spi_mosi),
        .spi_miso      (spi_miso),
        .spi_cs_n      (spi_cs_n),
        .pc_debug      (pc_debug),
        .inst_debug    (inst_debug),
        .rf_we         (rf_we),
        .rf_waddr      (rf_waddr),
        .rf_wdata      (rf_wdata),
        .br_taken_dbg  (br_taken_dbg),
        .trap_taken    (trap_taken),
        .epc_debug     (epc_debug),
        .timer_irq_dbg (timer_irq_dbg)
    );

    // Clock -------------------------------------------------------------------
    initial begin
        clk = 1'b0;
        forever #5 clk = ~clk;
    end

    // Simple SPI MISO loopback model ------------------------------------------
    // Return inverse of MOSI on each observed active transfer edge.
    always @(negedge spi_sck) begin
        if (!spi_cs_n)
            spi_miso <= ~spi_mosi;
    end

    // Stimulus ----------------------------------------------------------------
    initial begin
        $display("\n[TB] Starting tb_axi_wrapper...");
        $dumpfile("tb_axi_wrapper.vcd");
        $dumpvars(0, tb_axi_wrapper);

        rst     = 1'b1;
        gpio_in = 32'h1234_ABCD;
        spi_miso= 1'b0;

        repeat (5) @(posedge clk);
        rst = 1'b0;
        $display("[TB] Reset deasserted @ t=%0t", $time);

        repeat (200) @(posedge clk);

        // ---------------- Checks ----------------
        if (gpio_out !== 32'hA5A5_000F)
            $display("[TB][FAIL] GPIO_OUT mismatch. got=%h exp=%h", gpio_out, 32'hA5A5_000F);
        else
            $display("[TB][PASS] GPIO_OUT write observed: %h", gpio_out);

        if (dut.axi_dmem_i.mem[4] !== 32'h0000_003C)
            $display("[TB][FAIL] DMEM[0x10] mismatch. got=%h exp=%h", dut.axi_dmem_i.mem[4], 32'h0000_003C);
        else
            $display("[TB][PASS] DMEM write observed: %h", dut.axi_dmem_i.mem[4]);

        if (dut.axi_spi_i.tx_reg[7:0] !== 8'h5A)
            $display("[TB][FAIL] SPI TX register mismatch. got=%h exp=%h", dut.axi_spi_i.tx_reg[7:0], 8'h5A);
        else
            $display("[TB][PASS] SPI TX write observed: %h", dut.axi_spi_i.tx_reg[7:0]);

        $display("[TB] core observed GPIO readback  = %h", dut.mem_rdata);
        $display("[TB] SPI busy/done                = %b/%b", dut.axi_spi_i.spi_busy, dut.axi_spi_i.spi_done);
        $display("[TB] Finished @ t=%0t\n", $time);
        $finish;
    end

endmodule

